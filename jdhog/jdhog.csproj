<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Dalamud.NET.Sdk/14.0.2">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <PlatformTarget>x64</PlatformTarget>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Version>0.0.0.1</Version>
    <PackageLicenseExpression>AGPL-3.0-or-later</PackageLicenseExpression>
    <IsPackable>false</IsPackable>
    <RootNamespace>Jdhog</RootNamespace>
    <AssemblyName>jdhog</AssemblyName>
  </PropertyGroup>
  <PropertyGroup>
    <DalamudLibPath Condition="$(DALAMUD_HOME) != ''">$(DALAMUD_HOME)/</DalamudLibPath>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="backups\**" />
    <Compile Remove="**\backups\**" />
    <None Remove="backups\**" />
    <None Remove="**\backups\**" />
  </ItemGroup>
  <ItemGroup>
    <None Include="jdhog.json" CopyToOutputDirectory="PreserveNewest" />
    <None Include="images\**" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
